<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Car Hardware Permissions (for reading vehicle telemetry) -->
    <uses-permission android:name="com.google.android.gms.permission.CAR_FUEL" />
    <uses-permission android:name="com.google.android.gms.permission.CAR_MILEAGE" />
    <uses-permission android:name="com.google.android.gms.permission.CAR_SPEED" />

    <!-- Location (to tag refueling at gas station) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Internet (for potential future cloud sync) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service for location while refueling -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:name=".FuelTrackerApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FuelTracker">

        <!-- ===== MAIN PHONE ACTIVITY ===== -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FuelTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== ANDROID AUTO CAR APP SERVICE ===== -->
        <service
            android:name=".car.FuelTrackerCarAppService"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.IOT" />
            </intent-filter>
        </service>

        <!-- Car App description (required by Android Auto) -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <!-- ===== VOICE ACTION RECEIVER (Google Assistant) ===== -->
        <activity
            android:name=".voice.VoiceActionActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:host="fueltracker"
                    android:scheme="app" />
            </intent-filter>
        </activity>

        <!-- App Actions / Shortcuts metadata -->
        <meta-data
            android:name="android.app.shortcuts"
            android:resource="@xml/shortcuts" />

    </application>

</manifest>
